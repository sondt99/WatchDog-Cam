# Camera Hub - mau cau hinh Telegram
# Sao chep file nay thanh .env va dien thong tin that vao.
# Lay bot token tu @BotFather; lay chat ID bang cach them bot vao nhom
# roi mo https://api.telegram.org/bot<TOKEN>/getUpdates

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Chu ky gui anh (album tat ca camera gui 1 luot), don vi phut
TELEGRAM_PHOTO_INTERVAL_MINUTES=10

# Nguon quay video khi phat hien nguoi: "sub" = luong phu (nhe mang, khuyen
# dung) / "main" = full HD
TELEGRAM_VIDEO_SOURCE=sub

# (Tuy chon) fallback chu ky gui anh neu khong dat TELEGRAM_PHOTO_INTERVAL_MINUTES
#TELEGRAM_INTERVAL_MINUTES=10

# Dat =false de tat gui anh dinh ky ma khong can xoa token
#TELEGRAM_ENABLED=true

# ==== Phat hien nguoi (YOLOv8n, chay CPU) - video CHI gui khi co nguoi ====

# Dat =false de tat hoan toan tinh nang phat hien nguoi / gui video
#PERSON_DETECT_ENABLED=true

# Do dai clip dau tien khi vua phat hien nguoi (giay)
PERSON_FIRST_CLIP_SECONDS=20

# Neu nguoi con xuat hien lien tuc: moi doan clip tiep theo dai bao nhieu
# giay (mac dinh 60s = "moi phut gui 1 lan")
PERSON_CONTINUOUS_CLIP_SECONDS=60

# Sau khi khong con thay nguoi bao nhieu giay thi coi la nguoi da roi khoi
# khung hinh (dung de quyet dinh co ghi tiep doan clip ke tiep khong)
PERSON_GRACE_SECONDS=8

# (Nang cao) model YOLO, nguong tin cay, fps doc luong de detect, nguong %
# pixel thay doi de coi la co chuyen dong, va chu ky bat buoc kiem tra AI du
# khong co chuyen dong (giay) - thuong khong can chinh
#PERSON_DETECT_MODEL=yolov8n.pt
#PERSON_DETECT_CONF=0.5
#PERSON_DETECT_FPS=2
#PERSON_MOTION_THRESHOLD=1.5
#PERSON_FORCE_CHECK_SECONDS=5
