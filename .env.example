# Camera Hub - sample Telegram configuration
# Copy this file to .env and fill in the real information.
# Get the bot token from @BotFather; get the chat ID by adding the bot to
# the group then opening https://api.telegram.org/bot<TOKEN>/getUpdates

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Photo sending interval (all cameras sent as one album in one go), unit: minutes
TELEGRAM_PHOTO_INTERVAL_MINUTES=10

# Video source used when a person is detected: "sub" = sub stream (lighter on
# bandwidth, recommended) / "main" = full HD
TELEGRAM_VIDEO_SOURCE=sub

# (Optional) fallback photo sending interval if TELEGRAM_PHOTO_INTERVAL_MINUTES is not set
#TELEGRAM_INTERVAL_MINUTES=10

# Set =false to disable periodic photo sending without deleting the token
#TELEGRAM_ENABLED=true

# ==== Person detection (YOLOv8n, runs on CPU) - video is ONLY sent when a person is present ====

# Set =false to fully disable the person detection / video sending feature
#PERSON_DETECT_ENABLED=true

# Length of the first clip recorded as soon as a person is detected (seconds)
PERSON_FIRST_CLIP_SECONDS=20

# If the person keeps appearing continuously: length of each subsequent clip
# (default 60s = "send once per minute")
PERSON_CONTINUOUS_CLIP_SECONDS=60

# After how many seconds without seeing a person is it considered that the
# person has left the frame (used to decide whether to keep recording the next clip)
PERSON_GRACE_SECONDS=8

# A human must stay in frame for at least this long for the recorded VIDEO
# to be sent - filters out cars/motorbikes just passing by on the street.
# Recording starts immediately on first sighting (nothing is missed) and the
# instant alert photo is also sent immediately; a clip whose human left
# before this dwell time is silently discarded.
PERSON_MIN_DWELL_SECONDS=4

# (Advanced) Inference device, YOLO model, confidence threshold, inference
# resolution, stream fps for detection, pixel change percentage threshold to
# consider it motion, and the interval at which an AI check is forced even
# without motion (seconds) - usually no need to change
# Device: auto = use the NVIDIA GPU when visible (needs
# nvidia-container-toolkit + the GPU block in docker-compose.yml), else CPU
#PERSON_DETECT_DEVICE=auto
# Default model depends on device: GPU -> yolo11m.pt (much stronger, ~10ms l
# per check on GPU) / CPU -> yolov8s.pt (good balance at ~100ms per check).
# yolov8n.pt only if your machine is very weak - it misses seated/distant people.
#PERSON_DETECT_MODEL=yolo11m.pt
# Confidence threshold: raise it if you get false person alerts, lower it if
# real people get missed. Passing cars/motorbikes are filtered by
# PERSON_MIN_DWELL_SECONDS instead, so this can stay fairly low.
#PERSON_DETECT_CONF=0.35
# YOLO inference size in pixels - higher = more accurate on small/far/partly
# hidden shapes but slower per check (320-960)
#PERSON_DETECT_IMGSZ=640
#PERSON_DETECT_FPS=2
#PERSON_MOTION_THRESHOLD=1.5
#PERSON_FORCE_CHECK_SECONDS=5
